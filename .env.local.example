# Copy to a private template outside Git or use directly as an input template:
#   op inject -i .env.local.example -o .env.local
#
# Keep real 1Password references and injected values out of Git. The values
# below are placeholders only.

LINEAR_API_KEY="{{ op://<vault>/<item>/<linear-token-field> }}"

# Optional. Required only for encrypted snapshot publish/import once that
# pipeline ships.
# LINCRAWL_AGE_RECIPIENT="{{ op://<vault>/<item>/<age-recipient-field> }}"
# LINCRAWL_AGE_IDENTITY="{{ op://<vault>/<item>/<age-identity-field> }}"
# LINCRAWL_AGE_IDENTITY_FILE=".state/keys/lincrawl"

# Optional. Override the Linear API endpoint (default https://api.linear.app/graphql).
# LINCRAWL_LINEAR_BASE_URL=""

# Optional. Override the local archive home (default XDG data dir).
# LINCRAWL_HOME=""
