#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

before_tidy="$(mktemp)"
after_tidy="$(mktemp)"
coverage_out="$(mktemp)"
trap 'rm -f "$before_tidy" "$after_tidy" "$coverage_out"' EXIT

git diff -- go.mod go.sum >"$before_tidy"
go mod tidy
git diff -- go.mod go.sum >"$after_tidy"
if ! diff -u "$before_tidy" "$after_tidy"; then
  echo "go mod tidy changed go.mod or go.sum; run go mod tidy and commit the result" >&2
  exit 1
fi

go test -count=1 -coverprofile="$coverage_out" ./...

# cmd/lincrawl is a thin main() shim that just dispatches to internal/cli.Run;
# it cannot be exercised in-process, so filter it before computing the gate.
filtered_out="$(mktemp)"
trap 'rm -f "$before_tidy" "$after_tidy" "$coverage_out" "$filtered_out"' EXIT
grep -v 'cmd/lincrawl/main.go' "$coverage_out" >"$filtered_out"

total="$(go tool cover -func="$filtered_out" | awk '/^total:/ { sub(/%$/, "", $3); print $3 }')"
if [[ -z "$total" ]]; then
  echo "coverage profile produced no total; refusing to report" >&2
  exit 1
fi
printf 'coverage %.1f%%\n' "$total"

if awk -v t="$total" 'BEGIN { exit (t+0 < 85.0) ? 0 : 1 }'; then
  echo "coverage ${total}% is below the 85% gate" >&2
  echo "lowest-coverage symbols:" >&2
  go tool cover -func="$filtered_out" | awk '$3+0 < 85.0 && $3 != "0.0%" { print "  " $0 }' | head -10 >&2
  exit 1
fi

go vet ./...
go test -count=1 -race ./...
./scripts/smoke
go run ./cmd/lincrawl guard --json >/dev/null
./scripts/release-check
./scripts/lint
git diff --check

echo "verify ok"
