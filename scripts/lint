#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

staticcheck_version="v0.7.0"
gofumpt_version="v0.9.2"
govulncheck_version="v1.3.0"
gosec_version="v2.26.1"

gobin="$(go env GOBIN)"
if [[ -z "$gobin" ]]; then
	gobin="$(go env GOPATH)/bin"
fi

ensure_tool() {
	local bin="$1" pkg="$2" version="$3"
	if [[ -x "$gobin/$bin" ]] && go version -m "$gobin/$bin" 2>/dev/null | grep -qE "^\s+mod\s+[^[:space:]]+\s+$version(\s|$)"; then
		return
	fi
	echo "installing $bin@$version"
	GOBIN="$gobin" go install "$pkg@$version"
}

ensure_tool staticcheck honnef.co/go/tools/cmd/staticcheck "$staticcheck_version"
ensure_tool gofumpt mvdan.cc/gofumpt "$gofumpt_version"
ensure_tool govulncheck golang.org/x/vuln/cmd/govulncheck "$govulncheck_version"
ensure_tool gosec github.com/securego/gosec/v2/cmd/gosec "$gosec_version"

"$gobin/staticcheck" ./...

changed="$("$gobin/gofumpt" -l .)"
if [[ -n "$changed" ]]; then
	printf 'gofumpt wants changes in:\n%s\n' "$changed" >&2
	exit 1
fi

"$gobin/govulncheck" ./...

# G101 (hardcoded credentials) is owned by guard; G104 (unchecked errors) is too noisy on
# idiomatic Body.Close / discard patterns; G115/G202/G301/G304 fire on safe ergonomic uses.
"$gobin/gosec" -quiet -exclude=G101,G104,G115,G202,G301,G304 ./...

echo "lint ok"
