# Copy to .env.local and fill in values. .env.local is git-ignored.
#
# Read-only Linear API token. Required for any live sync (--updated-since,
# --issue, --entities). Not needed for `--fixture` runs.
LINEAR_API_KEY=

# Optional: override the Linear API endpoint (default https://api.linear.app/graphql).
# LINCRAWL_LINEAR_BASE_URL=

# Optional: override the local archive home. Default uses XDG data dir.
# LINCRAWL_HOME=

# Optional: age recipient/identity for encrypted archive output, mirrors fincrawl.
# LINCRAWL_AGE_RECIPIENT=
# LINCRAWL_AGE_IDENTITY=
